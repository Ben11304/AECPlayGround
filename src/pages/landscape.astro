---
import Layout from '../layouts/Layout.astro';
import TierBadge from '../components/TierBadge.astro';
import { benchmarks, toSlug } from '../lib/benchmarks';

// Group by year, then by tier within year
const years = [...new Set(benchmarks.map((b) => b.bibliographic.year).filter(Boolean))].sort() as number[];

type TierMap = { 1: typeof benchmarks; 2: typeof benchmarks; 3: typeof benchmarks };
const byYear: Record<number, TierMap> = {};
for (const year of years) {
  byYear[year] = { 1: [], 2: [], 3: [] };
}
for (const b of benchmarks) {
  const yr = b.bibliographic.year;
  if (yr && byYear[yr]) {
    (byYear[yr] as TierMap)[b.tier as 1 | 2 | 3].push(b);
  }
}

const tierColors = {
  1: 'border-emerald-700 bg-emerald-950/50 hover:bg-emerald-900/40',
  2: 'border-amber-700 bg-amber-950/50 hover:bg-amber-900/40',
  3: 'border-orange-700 bg-orange-950/50 hover:bg-orange-900/40',
};
const tierDot = { 1: 'bg-emerald-500', 2: 'bg-amber-500', 3: 'bg-orange-500' };
const tierLabel = { 1: 'T1 — Core', 2: 'T2 — Peripheral', 3: 'T3 — Contextual' };
---

<Layout title="Landscape View" description="AEC Benchmark landscape: tier × year visualization of all 20 included benchmarks.">
  <!-- Page header -->
  <div class="page-header">
    <div class="mx-auto max-w-7xl">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="breadcrumb-sep" aria-hidden="true">›</span>
        <span class="text-slate-400" aria-current="page">Landscape</span>
      </nav>
      <p class="section-label">Tier × Year</p>
      <h1 class="font-display text-3xl font-bold text-white mb-2">Benchmark Landscape</h1>
      <p class="text-slate-400 text-sm max-w-xl">
        20 benchmarks positioned by publication year and quality tier.
        Each card links to the full detail page.
      </p>
    </div>
  </div>

  <div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
    <!-- Legend -->
    <div class="mb-8 flex flex-wrap gap-4">
      {([1, 2, 3] as const).map((t) => (
        <div class="flex items-center gap-2">
          <div class={`h-3 w-3 rounded-full ${tierDot[t]}`}></div>
          <span class="text-xs text-slate-400">{tierLabel[t]}</span>
        </div>
      ))}
    </div>

    <!-- Year columns -->
    <div class="grid gap-6" style="grid-template-columns: repeat(auto-fit, minmax(280px, 1fr))">
      {years.map((year) => (
        <div class="flex flex-col gap-1">
          <!-- Year header -->
          <div class="mb-3 flex items-center gap-2">
            <span class="text-xl font-bold text-slate-200">{year}</span>
            <span class="chip bg-slate-800 text-slate-500 text-[10px]">
              {benchmarks.filter((b) => b.bibliographic.year === year).length} benchmarks
            </span>
          </div>

          <!-- Tier rows within year -->
          {([1, 2, 3] as const).map((tier) => {
            const items = byYear[year][tier];
            if (items.length === 0) return null;
            return (
              <div class="mb-4">
                <div class="mb-1.5 flex items-center gap-1.5">
                  <div class={`h-2 w-2 rounded-full ${tierDot[tier]}`}></div>
                  <span class="text-[10px] font-semibold uppercase tracking-wider text-slate-500">
                    {tierLabel[tier]}
                  </span>
                </div>
                <div class="flex flex-col gap-2">
                  {items.map((b) => (
                    <a
                      href={`/benchmarks/${toSlug(b.source_record_id)}`}
                      class={`rounded-lg border px-3 py-2 transition-all cursor-pointer no-underline ${tierColors[tier]}`}
                    >
                      <div class="flex items-start justify-between gap-2">
                        <div>
                          <span class="text-sm font-medium text-slate-100">{b.name}</span>
                          <p class="mt-0.5 text-[10px] text-slate-500 leading-tight">
                            {b.capability.domain.split(';')[0].trim()}
                          </p>
                        </div>
                        <div class="flex shrink-0 flex-col items-end gap-1">
                          <span class="font-mono text-[10px] text-slate-500">{b.source_record_id}</span>
                          <span class="text-[10px] text-slate-500">{b.rubric?.total}/20</span>
                        </div>
                      </div>
                    </a>
                  ))}
                </div>
              </div>
            );
          })}
        </div>
      ))}
    </div>

    <!-- Summary table -->
    <div class="mt-12 overflow-x-auto rounded-xl border border-slate-800">
      <table class="min-w-full text-sm">
        <thead class="bg-slate-900">
          <tr>
            <th class="py-3 px-4 text-left text-[10px] font-semibold uppercase tracking-wider text-slate-500">Year</th>
            <th class="py-3 px-4 text-center text-[10px] font-semibold uppercase tracking-wider text-emerald-600">T1 Core</th>
            <th class="py-3 px-4 text-center text-[10px] font-semibold uppercase tracking-wider text-amber-600">T2 Peripheral</th>
            <th class="py-3 px-4 text-center text-[10px] font-semibold uppercase tracking-wider text-orange-600">T3 Contextual</th>
            <th class="py-3 px-4 text-center text-[10px] font-semibold uppercase tracking-wider text-slate-500">Total</th>
          </tr>
        </thead>
        <tbody>
          {years.map((year, i) => {
            const row = byYear[year];
            const total = row[1].length + row[2].length + row[3].length;
            return (
              <tr class={i % 2 === 0 ? 'bg-slate-950' : 'bg-slate-900/50'}>
                <td class="py-2.5 px-4 font-semibold text-slate-300">{year}</td>
                <td class="py-2.5 px-4 text-center text-emerald-400">{row[1].length || '—'}</td>
                <td class="py-2.5 px-4 text-center text-amber-400">{row[2].length || '—'}</td>
                <td class="py-2.5 px-4 text-center text-orange-400">{row[3].length || '—'}</td>
                <td class="py-2.5 px-4 text-center font-semibold text-slate-200">{total}</td>
              </tr>
            );
          })}
          <!-- Total row -->
          <tr class="bg-slate-800/60 font-semibold">
            <td class="py-2.5 px-4 text-slate-200">Total</td>
            <td class="py-2.5 px-4 text-center text-emerald-300">13</td>
            <td class="py-2.5 px-4 text-center text-amber-300">6</td>
            <td class="py-2.5 px-4 text-center text-orange-300">1</td>
            <td class="py-2.5 px-4 text-center text-white">20</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</Layout>
