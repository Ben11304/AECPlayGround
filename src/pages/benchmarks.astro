---
import Layout from '../layouts/Layout.astro';
import FilterBar from '../components/FilterBar.astro';
import BenchmarkCard from '../components/BenchmarkCard.astro';
import { benchmarks } from '../lib/benchmarks';

// Default sort: tier then rubric score (tiebreak only — tier is a FILTER, not a
// grouping; the grid below is flat, not sectioned by tier per user request).
const sorted = [...benchmarks].sort((a, b) => {
  if (a.tier !== b.tier) return a.tier - b.tier;
  return (b.rubric?.total ?? 0) - (a.rubric?.total ?? 0);
});

const t1 = sorted.filter(b => b.tier === 1);
const t2 = sorted.filter(b => b.tier === 2);
const t3 = sorted.filter(b => b.tier === 3);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout
  title="Benchmarks"
  description={`All ${benchmarks.length} AEC AI benchmarks from the PRISMA systematic review — filterable by taxonomy (Dim1-6: Task, Capability, Modality, Evaluation, Profession, Building-system), tier, and domain.`}
>

  <!-- Page header -->
  <div class="page-header">
    <div class="mx-auto max-w-7xl">
      <!-- Breadcrumb -->
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href={`${base}/`}>Home</a>
        <span class="breadcrumb-sep" aria-hidden="true">›</span>
        <span class="text-slate-600" aria-current="page">Benchmarks</span>
      </nav>

      <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p class="section-label">Full Catalog</p>
          <h1 class="font-display text-3xl font-bold text-slate-900 sm:text-4xl mb-2">
            All AEC Benchmarks
          </h1>
          <p class="text-slate-600 text-sm max-w-2xl">
            {benchmarks.length} benchmarks curated by a PRISMA systematic review
            (178 identified → 164 screened → 43 full-text → 32 included through a fully
            reconciled funnel, plus 11 more via a later scope extension and a user-submitted
            full-text batch whose own funnel arithmetic is pending reconciliation →
            {benchmarks.length} total).
            Filter below by taxonomy dimension (Dim1 Task · Dim2 Capability · Dim3 Modality ·
            Dim4 Evaluation · Dim5 Profession · Dim6 Building-system), tier, or domain — tier is
            one filterable attribute among several, not the primary grouping.
          </p>
        </div>
        <div class="flex gap-6 shrink-0">
          {[
            { label: 'Tier 1', value: String(t1.length), sub: 'core',       cls: 'text-emerald-700' },
            { label: 'Tier 2', value: String(t2.length), sub: 'peripheral', cls: 'text-amber-700' },
            { label: 'Tier 3', value: String(t3.length), sub: 'contextual', cls: 'text-orange-700' },
          ].map(s => (
            <div class="text-center">
              <div class={`font-display text-2xl font-bold ${s.cls}`}>{s.value}</div>
              <div class="text-[10px] font-medium text-slate-600 uppercase tracking-wide">{s.label}</div>
              <div class="text-[10px] text-slate-600">{s.sub}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- Filter bar (sticky) -->
  <FilterBar />

  <!-- Card grid: flat, not grouped by tier — use the Tier filter chips above to narrow -->
  <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
      {sorted.map(b => <BenchmarkCard benchmark={b} />)}
    </div>

    <!-- No-results message -->
    <div id="no-results-msg" class="hidden py-20 text-center text-slate-500">
      <p class="text-lg mb-2">No benchmarks match your filters.</p>
      <button
        onclick="document.getElementById('reset-filters')?.click()"
        class="text-sm text-primary-700 hover:text-primary-700 transition-colors"
      >
        Reset filters
      </button>
    </div>
  </div>
</Layout>

<script>
const observer = new MutationObserver(() => {
  const visible = Array.from(document.querySelectorAll('[data-id]'))
    .filter(el => (el as HTMLElement).style.display !== 'none');
  const msg = document.getElementById('no-results-msg');
  if (msg) msg.classList.toggle('hidden', visible.length > 0);
});
document.querySelectorAll('[data-id]').forEach(card => {
  observer.observe(card, { attributes: true, attributeFilter: ['style'] });
});
</script>
