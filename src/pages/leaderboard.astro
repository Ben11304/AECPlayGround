---
import Layout from '../layouts/Layout.astro';
import { benchmarks } from '../lib/benchmarks';
import { YEAR_LOOKUP } from '../lib/year_lookup';

// Dynamic: all benchmarks sorted tier ASC then name ASC.
// No hardcoded pilot set — every record with ≥1 source_confirmed row is chartable.
const allSorted = [...benchmarks].sort((a, b) => {
  if (a.tier !== b.tier) return (a.tier as number) - (b.tier as number);
  return a.name.localeCompare(b.name);
});
const withResults = allSorted.filter(b =>
  (b.reported_results ?? []).some((r: any) => r.provenance_flag === 'source_confirmed')
);
const noResults = allSorted.filter(b =>
  !(b.reported_results ?? []).some((r: any) => r.provenance_flag === 'source_confirmed')
);

// Paywall records: no PDF exists, ASCE paywall
const PAYWALL_IDS = new Set(['R004', 'R033']);

// Build per-benchmark map of figure-only models (roster confirmed, values chart-only)
const figureOnlyMap: Record<string, string[]> = {};
for (const b of allSorted) {
  const models = (b.reported_results ?? [])
    .filter((r: any) => r.provenance_flag === 'source_confirmed_model_figure_only_value')
    .map((r: any) => r.model_string as string);
  const unique = [...new Set(models)];
  if (unique.length > 0) figureOnlyMap[b.source_record_id] = unique;
}

// IDs for client-side selectors (ordered)
const BM_ORDER = allSorted.map(b => b.source_record_id);
const LB_NO_RESULTS_IDS = noResults.map(b => b.source_record_id);
const LB_PILOT = withResults.map(b => b.source_record_id);

// Slim data for client (records with source_confirmed results — figure-only rows excluded from chart payload)
const chartBenchmarks = withResults.map(b => ({
  source_record_id: b.source_record_id,
  name: b.name,
  tier: b.tier,
  reported_results: (b.reported_results ?? []).filter((r: any) => r.provenance_flag === 'source_confirmed'),
  identifier: b.identifier,
}));

// Source-confirmed row counts per chartable benchmark (for coverage table)
const confirmedCounts: Record<string, number> = {};
for (const b of chartBenchmarks) {
  confirmedCounts[b.source_record_id] = (b.reported_results as any[]).filter(
    (r: any) => r.provenance_flag === 'source_confirmed'
  ).length;
}

// Serialize for client
const _chartData = JSON.stringify(chartBenchmarks);
const _yearLookup = JSON.stringify(YEAR_LOOKUP);
const _lbNoResults = JSON.stringify(LB_NO_RESULTS_IDS);
const _lbPilot = JSON.stringify(LB_PILOT);
const _bmOrder = JSON.stringify(BM_ORDER);
const _figureOnlyMap = JSON.stringify(figureOnlyMap);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="Leaderboard" description="AEC Benchmark Leaderboard — model performance across source-confirmed benchmarks: bar, scatter, year-axis charts.">
  <!-- Page header -->
  <div class="page-header">
    <div class="mx-auto max-w-7xl">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href={`${base}/`}>Home</a>
        <span class="breadcrumb-sep" aria-hidden="true">›</span>
        <span class="text-slate-600" aria-current="page">Leaderboard</span>
      </nav>
      <p class="section-label">Model Performance</p>
      <h1 class="font-display text-3xl font-bold text-slate-900 mb-2">Model Leaderboard</h1>
      <p class="text-slate-600 text-sm max-w-xl">
        Source-confirmed results only · Bar / Scatter / Year-axis charts · Integrity-gated
      </p>
    </div>
  </div>

  <div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">

    <!-- Integrity caveat bar -->
    <div class="mb-4 flex flex-wrap items-center gap-3 rounded-lg border border-slate-200 bg-slate-50/60 px-4 py-3 text-xs">
      <span class="chip badge-verified text-[11px]">✓ source-confirmed</span>
      <span class="text-slate-600">Sourced as of 2026-06</span>
      <span class="text-slate-700">·</span>
      <span class="text-slate-500">Model strings verbatim from 2026 papers</span>
      <span class="text-slate-700">·</span>
      <span class="text-slate-500">Numbers may change as models update</span>
    </div>

    <!-- Main interactive chart card -->
    <div class="rounded-xl border border-slate-200 bg-white overflow-hidden">

      <!-- Controls bar -->
      <div class="border-b border-slate-200 bg-slate-50/80 px-4 py-3 flex flex-wrap items-center gap-3">
        <!-- Benchmark select -->
        <div class="flex items-center gap-2">
          <label for="lbBmSel" class="text-[10px] font-semibold uppercase tracking-wider text-slate-500 shrink-0">Benchmark</label>
          <select id="lbBmSel" class="lb-select">
            <option value="">Loading…</option>
          </select>
        </div>

        <!-- Mode toggle -->
        <div id="lb-mode-toggle" class="flex rounded-lg border border-slate-300 overflow-hidden text-xs">
          <button id="modeBar" class="lb-mode-btn px-3 py-1.5 font-medium transition-colors active" aria-pressed="true">
            Bar
          </button>
          <button id="modeScatter" class="lb-mode-btn px-3 py-1.5 font-medium transition-colors border-l border-slate-300" aria-pressed="false">
            Scatter
          </button>
        </div>

        <!-- Bar controls -->
        <div id="barControls" class="flex items-center gap-2">
          <label for="lbMetSel" class="text-[10px] font-semibold uppercase tracking-wider text-slate-500 shrink-0">Metric</label>
          <select id="lbMetSel" class="lb-select">
            <option value="">—</option>
          </select>
        </div>

        <!-- Scatter controls -->
        <div id="scatterControls" class="hidden flex-wrap items-center gap-2">
          <label class="text-[10px] font-semibold uppercase tracking-wider text-slate-500">X axis</label>
          <select id="lbXSel" class="lb-select"></select>
          <label class="text-[10px] font-semibold uppercase tracking-wider text-slate-500">Y axis</label>
          <select id="lbYSel" class="lb-select"></select>
        </div>
      </div>

      <!-- Chart area -->
      <div id="lbChartWrap" class="min-h-[300px] p-4 flex items-center justify-center">
        <p class="text-slate-500 text-sm">Loading chart…</p>
      </div>

      <!-- Legend row -->
      <div class="border-t border-slate-200 px-4 py-2 flex flex-wrap gap-4 text-xs text-slate-500">
        <div class="flex items-center gap-1.5">
          <div class="h-3 w-3 rounded bg-blue-500 opacity-90"></div>
          <span>AI model</span>
        </div>
        <div class="flex items-center gap-1.5">
          <div class="h-3 w-3 rounded bg-amber-500 opacity-90"></div>
          <span>Human reference</span>
        </div>
        <div class="flex items-center gap-1.5">
          <div class="h-3 w-3 rounded-sm border-2 border-dashed border-violet-400 opacity-80"></div>
          <span>Approx. year (◎)</span>
        </div>
      </div>
      <!-- Figure-only notice (populated by client JS when applicable) -->
      <div id="lbFigureOnlyPanel" class="hidden border-t border-slate-200 bg-violet-50/50 px-4 py-3">
        <p class="text-[11px] font-semibold text-violet-700 mb-1">
          ◈ Figure-only models for this benchmark — roster confirmed, numeric values in paper charts only
        </p>
        <p id="lbFigureOnlyList" class="text-[11px] text-violet-600"></p>
      </div>
    </div>

    <!-- Integrity gating notices -->
    <div class="mt-6 space-y-3">
      <!-- Paywall records: no PDF exists -->
      {noResults.filter(b => PAYWALL_IDS.has(b.source_record_id)).length > 0 && (
        <div class="rounded-xl border border-amber-200/60 bg-amber-50/40 p-4">
          <h3 class="text-xs font-semibold text-amber-700 mb-2">⟨paywall — no extractable data⟩ — {noResults.filter(b => PAYWALL_IDS.has(b.source_record_id)).length} benchmarks</h3>
          <p class="text-[11px] text-amber-600 mb-2">
            No PDF available (ASCE paywall, no preprint). Full-text screening was completed at title/abstract; these benchmarks are included in the corpus count but no performance numbers could be extracted. Disabled in selector.
          </p>
          <div class="flex flex-wrap gap-1">
            {noResults.filter(b => PAYWALL_IDS.has(b.source_record_id)).map(b => (
              <a href={`${base}/benchmarks/${b.source_record_id.toLowerCase()}`}
                 class="chip bg-amber-100 text-amber-700 border border-amber-300 font-mono text-[10px] hover:bg-amber-200">
                {b.source_record_id} {b.name}
              </a>
            ))}
          </div>
        </div>
      )}
      <!-- Other no-results records (non-paywall) -->
      {noResults.filter(b => !PAYWALL_IDS.has(b.source_record_id)).length > 0 && (
        <div class="rounded-xl border border-slate-300/40 bg-slate-100/20 p-4">
          <h3 class="text-xs font-semibold text-slate-600 mb-2">⟨no reported results⟩ — {noResults.filter(b => !PAYWALL_IDS.has(b.source_record_id)).length} benchmarks</h3>
          <p class="text-[11px] text-slate-500 mb-2">
            No extractable performance data (pending extraction). Disabled in selector.
          </p>
          <div class="flex flex-wrap gap-1">
            {noResults.filter(b => !PAYWALL_IDS.has(b.source_record_id)).map(b => (
              <a href={`${base}/benchmarks/${b.source_record_id.toLowerCase()}`}
                 class="chip bg-slate-300/50 text-slate-600 border border-slate-300 font-mono text-[10px] hover:bg-slate-300/80">
                {b.source_record_id} {b.name}
              </a>
            ))}
          </div>
        </div>
      )}
    </div>

    <!-- Coverage summary -->
    <div class="mt-6 rounded-xl border border-slate-200 overflow-hidden">
      <div class="bg-white px-4 py-3">
        <h3 class="text-sm font-semibold text-slate-800">Coverage summary — {withResults.length} chartable benchmarks · metrics are per-benchmark only, not cross-comparable</h3>
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-full text-xs">
          <thead class="bg-slate-50/60">
            <tr>
              <th class="py-2 px-4 text-left text-[10px] font-semibold uppercase tracking-wider text-slate-500">Benchmark</th>
              <th class="py-2 px-4 text-left text-[10px] font-semibold uppercase tracking-wider text-slate-500">ID</th>
              <th class="py-2 px-4 text-center text-[10px] font-semibold uppercase tracking-wider text-emerald-600">✓ Source-confirmed rows</th>
            </tr>
          </thead>
          <tbody>
            {withResults.map((b, i) => {
              const rid = b.source_record_id;
              const cnt = confirmedCounts[rid] ?? 0;
              return (
                <tr class={i % 2 === 0 ? 'bg-white' : 'bg-slate-50/40'}>
                  <td class="py-2 px-4">
                    <a href={`${base}/benchmarks/${rid.toLowerCase()}`}
                       class="text-slate-700 hover:text-blue-700 transition-colors">
                      {b.name}
                    </a>
                  </td>
                  <td class="py-2 px-4 font-mono text-[11px] text-slate-500">{rid}</td>
                  <td class="py-2 px-4 text-center font-semibold text-emerald-700">{cnt}</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>

    <!-- R032 exclusion note -->
    <p class="mt-4 text-center text-[11px] text-slate-700">
      R032 (VS-BIM / CER-QA) excluded per VERIFIER 0.5.23 F-054 — framework-internal benchmark, no public standalone release.
    </p>

  </div>
</Layout>

<!-- Inline styles for the chart UI -->
<style>
.lb-select {
  @apply rounded-lg border border-slate-300 bg-slate-100 px-2.5 py-1.5
         text-xs text-slate-800 focus:border-blue-500 focus:outline-none
         focus:ring-1 focus:ring-blue-500/30 transition max-w-[280px];
}
.lb-mode-btn {
  @apply bg-white text-slate-600 hover:text-slate-800;
}
.lb-mode-btn.active {
  @apply bg-blue-700 text-white;
}
.lb-warn {
  @apply rounded-lg border border-amber-200 bg-amber-50 p-4 text-sm text-amber-700;
}
.lb-info {
  @apply rounded-lg border border-slate-300/40 bg-slate-100/20 p-3 text-xs text-slate-500 mt-2;
}
</style>

<!-- All chart logic — client-side, no CDN deps -->
<script define:vars={{ _chartData, _yearLookup, _lbNoResults, _lbPilot, _bmOrder, _figureOnlyMap }}>
const DATA = JSON.parse(_chartData);
const YEAR_LOOKUP = JSON.parse(_yearLookup);
const LB_NO_RESULTS = new Set(JSON.parse(_lbNoResults));
const LB_PILOT = new Set(JSON.parse(_lbPilot));
const BM_ORDER = JSON.parse(_bmOrder);
const FIGURE_ONLY_MAP = JSON.parse(_figureOnlyMap);

// ── State ──────────────────────────────────────────────────────────────────
let _lbRid = 'R001';
let _lbMode = 'bar';
let _lbMetric = null;
let _lbXMetric = null;
let _lbYMetric = null;

// ── Helpers ────────────────────────────────────────────────────────────────
function lbParseVal(v) {
  if (v === null || v === undefined || v === '') return null;
  const s = String(v).replace(/%$/, '').replace(/,/g, '').trim();
  const n = parseFloat(s);
  return isNaN(n) ? null : n;
}
function getMetrics(rid) {
  const d = DATA.find(x => x.source_record_id === rid);
  if (!d) return [];
  return [...new Set(
    (d.reported_results || [])
      .filter(r => r.provenance_flag === 'source_confirmed')
      .map(r => r.metric_name)
  )].sort();
}
function getRows(rid, metric) {
  const d = DATA.find(x => x.source_record_id === rid);
  if (!d) return [];
  return (d.reported_results || []).filter(
    r => r.metric_name === metric && r.provenance_flag === 'source_confirmed'
  );
}

// ── Select builders ────────────────────────────────────────────────────────
function buildBmSelect() {
  const sel = document.getElementById('lbBmSel');
  if (!sel) return;
  sel.innerHTML = BM_ORDER.map(rid => {
    const isNoRes = LB_NO_RESULTS.has(rid);
    if (isNoRes) {
      return `<option value="${rid}" disabled>${rid} ⟨no results⟩</option>`;
    }
    const d = DATA.find(x => x.source_record_id === rid);
    if (!d) return '';
    const sel2 = rid === _lbRid ? 'selected' : '';
    return `<option value="${rid}" ${sel2}>${d.name}</option>`;
  }).join('');
}

function buildMetSelect(metrics, selected, elemId) {
  const sel = document.getElementById(elemId);
  if (!sel) return;
  sel.innerHTML = metrics.map(m =>
    `<option value="${m}" ${m === selected ? 'selected' : ''}>${m}</option>`
  ).join('');
}

const YEAR_OPT_LABEL = 'Model release year (VERIFIER-checked 2026-06)';
function buildAxisSelect(metrics, selected, elemId) {
  const sel = document.getElementById(elemId);
  if (!sel) return;
  const metricOpts = metrics.map(m =>
    `<option value="${m}" ${m === selected ? 'selected' : ''}>${m}</option>`
  ).join('');
  const yearSel = selected === '__year__' ? 'selected' : '';
  sel.innerHTML = metricOpts +
    `<option disabled>──────────</option>` +
    `<option value="__year__" ${yearSel}>${YEAR_OPT_LABEL}</option>`;
}

// ── Mode UI ────────────────────────────────────────────────────────────────
function setMode(mode) {
  _lbMode = mode;
  document.getElementById('modeBar').classList.toggle('active', mode === 'bar');
  document.getElementById('modeBar').setAttribute('aria-pressed', mode === 'bar');
  document.getElementById('modeScatter').classList.toggle('active', mode === 'scatter');
  document.getElementById('modeScatter').setAttribute('aria-pressed', mode === 'scatter');
  document.getElementById('barControls').classList.toggle('hidden', mode !== 'bar');
  const sc = document.getElementById('scatterControls');
  sc.classList.toggle('hidden', mode !== 'scatter');
  sc.classList.toggle('flex', mode === 'scatter');
  renderChart();
}

// ── Figure-only panel update ───────────────────────────────────────────────
function updateFigureOnlyPanel(rid) {
  const panel = document.getElementById('lbFigureOnlyPanel');
  const list = document.getElementById('lbFigureOnlyList');
  if (!panel || !list) return;
  const models = FIGURE_ONLY_MAP[rid];
  if (models && models.length > 0) {
    list.textContent = models.join(' · ');
    panel.classList.remove('hidden');
  } else {
    panel.classList.add('hidden');
    list.textContent = '';
  }
}

// ── Main render ────────────────────────────────────────────────────────────
function renderChart() {
  const wrap = document.getElementById('lbChartWrap');
  if (!wrap) return;
  if (!_lbRid) { wrap.innerHTML = '<p class="text-slate-500 text-sm">Select a benchmark.</p>'; return; }
  updateFigureOnlyPanel(_lbRid);
  if (_lbMode === 'bar') {
    if (!_lbMetric) { wrap.innerHTML = '<p class="text-slate-500 text-sm">Select a metric.</p>'; return; }
    wrap.innerHTML = buildBarChart(_lbRid, _lbMetric);
  } else {
    if (!_lbXMetric || !_lbYMetric) { wrap.innerHTML = '<p class="text-slate-500 text-sm">Select both axes.</p>'; return; }
    wrap.innerHTML = buildScatterChart(_lbRid, _lbXMetric, _lbYMetric);
  }
}

// ── BAR CHART ─────────────────────────────────────────────────────────────
function buildBarChart(rid, metric) {
  const rows = getRows(rid, metric);
  if (rows.length === 0) return '<p class="text-slate-500 text-sm p-4">No source-confirmed data for this metric.</p>';

  const parsed = rows.map(r => ({
    model: r.model_string, rawVal: r.value,
    val: lbParseVal(r.value),
    isHuman: /human/i.test(r.model_string),
    src: r.source_location || '',
  })).filter(r => r.val !== null);
  if (parsed.length === 0) return '<p class="text-slate-500 text-sm p-4">Values are not numeric for this metric.</p>';

  const aiRows = parsed.filter(r => !r.isHuman).sort((a, b) => b.val - a.val);
  const humRows = parsed.filter(r => r.isHuman).sort((a, b) => b.val - a.val);
  const allRows = [...aiRows, ...humRows];

  const maxVal = Math.max(...allRows.map(r => r.val));
  const dispMax = maxVal <= 0 ? 1 : maxVal * 1.08;

  const LW = 200, VW = 72, TW = 672, BA = TW - LW - VW;
  const BH = 22, GAP = 5, RH = BH + GAP, TM = 36, BM = 22;
  const SVG_H = TM + allRows.length * RH + BM;

  const textC = '#1e293b';
  const dimC  = '#475569';
  const gridC = '#e2e8f0';
  const aiC   = '#3b82f6';
  const humC  = '#f59e0b';

  const src0 = allRows[0].src;
  const axM = src0.match(/arXiv:(\d{4}\.\d{4,})/i);
  const doiM = src0.match(/10\.\d{4,}\/[^\s,]+/);
  const srcHref = axM ? `https://arxiv.org/abs/${axM[1]}` : (doiM ? `https://doi.org/${doiM[0]}` : null);
  const srcLabel = src0.replace(/^Table \d+,\s*/, '').slice(0, 60);

  let ticks = '';
  const NT = 5;
  for (let i = 0; i <= NT; i++) {
    const tv = dispMax * i / NT;
    const tx = LW + (tv / dispMax) * BA;
    const tl = tv < 1 ? tv.toFixed(2) : tv >= 100 ? Math.round(tv).toString() : tv.toFixed(1);
    ticks += `<line x1="${tx.toFixed(1)}" y1="${TM - 4}" x2="${tx.toFixed(1)}" y2="${(TM + allRows.length * RH).toFixed(1)}" stroke="${gridC}" stroke-width="1" stroke-dasharray="3 3"/>`;
    ticks += `<text x="${tx.toFixed(1)}" y="${TM - 10}" text-anchor="middle" font-size="9" fill="${dimC}">${tl}</text>`;
  }
  ticks += `<line x1="${LW}" y1="${TM - 4}" x2="${LW + BA}" y2="${TM - 4}" stroke="${gridC}" stroke-width="1"/>`;

  let bars = '';
  allRows.forEach((r, i) => {
    const y = TM + i * RH;
    const bw = Math.max(2, (r.val / dispMax) * BA);
    const fc = r.isHuman ? humC : aiC;
    const lbl = r.model.length > 30 ? r.model.slice(0, 29) + '…' : r.model;
    const fw = r.isHuman ? '700' : '400';
    bars += `<g>
      <text x="${LW - 6}" y="${(y + BH / 2 + 1).toFixed(1)}" text-anchor="end" dominant-baseline="middle" font-size="11" fill="${r.isHuman ? humC : textC}" font-weight="${fw}">${lbl.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')}</text>
      <rect x="${LW}" y="${(y + 1).toFixed(1)}" width="${bw.toFixed(1)}" height="${BH - 2}" fill="${fc}" opacity="${r.isHuman ? '0.75' : '0.9'}" rx="2"/>
      <text x="${(LW + bw + 5).toFixed(1)}" y="${(y + BH / 2 + 1).toFixed(1)}" text-anchor="start" dominant-baseline="middle" font-size="11" fill="${fc}" font-weight="600">${r.rawVal}</text>
    </g>`;
    bars += `<line x1="${LW}" y1="${y.toFixed(1)}" x2="${LW + BA}" y2="${y.toFixed(1)}" stroke="${gridC}" stroke-width="0.5"/>`;
  });

  let sep = '';
  if (humRows.length > 0 && aiRows.length > 0) {
    const sy = (TM + aiRows.length * RH - 2).toFixed(1);
    sep = `<line x1="${LW - 30}" y1="${sy}" x2="${LW + BA}" y2="${sy}" stroke="${humC}" stroke-width="1" stroke-dasharray="4 3" opacity="0.6"/>
           <text x="${LW - 32}" y="${sy}" text-anchor="end" font-size="9" fill="${humC}" opacity="0.8">▼ human ref</text>`;
  }

  const srcNote = srcHref
    ? `<a href="${srcHref}" target="_blank" rel="noopener"><text x="${TW - 4}" y="${SVG_H - 5}" text-anchor="end" font-size="9" fill="${dimC}" text-decoration="underline">↗ ${srcLabel}</text></a>`
    : `<text x="${TW - 4}" y="${SVG_H - 5}" text-anchor="end" font-size="9" fill="${dimC}">${srcLabel}</text>`;

  const metricTitle = metric.replace(/&/g,'&amp;').replace(/</g,'&lt;');

  return `<svg viewBox="0 0 ${TW} ${SVG_H}" width="100%" style="max-width:${TW}px;display:block" role="img" aria-label="Leaderboard: ${metricTitle}">
    <title>${metricTitle} — model leaderboard (source-confirmed, CRAFTER 0.6.0)</title>
    ${ticks}${bars}${sep}${srcNote}
  </svg>`;
}

// ── SCATTER CHART ──────────────────────────────────────────────────────────
function buildScatterChart(rid, xMetric, yMetric) {
  if (xMetric === yMetric) {
    return '<p class="text-amber-700 text-sm p-4">⚠ X and Y axes are the same — select different metrics to reveal trade-offs.</p>';
  }

  const d = DATA.find(x => x.source_record_id === rid);
  if (!d) return '<p class="text-slate-500 text-sm p-4">Benchmark not found.</p>';

  const rr = (d.reported_results || []).filter(r => r.provenance_flag === 'source_confirmed');

  const IS_YR_X = xMetric === '__year__';
  const IS_YR_Y = yMetric === '__year__';
  const xDispName = IS_YR_X ? 'Release year' : xMetric;
  const yDispName = IS_YR_Y ? 'Release year' : yMetric;

  const modelMap = {};
  const needMetrics = [xMetric, yMetric].filter(m => m !== '__year__');
  rr.forEach(r => {
    if (!needMetrics.includes(r.metric_name)) return;
    if (!modelMap[r.model_string]) {
      modelMap[r.model_string] = {
        model: r.model_string, vals: {},
        isHuman: /human/i.test(r.model_string),
        src: r.source_location || '', _approx: false,
      };
    }
    const mv = lbParseVal(r.value);
    if (mv !== null && !modelMap[r.model_string].vals[r.metric_name]) {
      modelMap[r.model_string].vals[r.metric_name] = { parsed: mv, raw: r.value };
    }
  });

  let yearOmitCount = 0;
  if (IS_YR_X || IS_YR_Y) {
    Object.keys(modelMap).forEach(ms => {
      const entry = YEAR_LOOKUP[ms];
      if (!entry || entry.plot_flag === 'omit') {
        yearOmitCount++;
        delete modelMap[ms];
        return;
      }
      const yr = entry.release_year + (entry.release_month ? (entry.release_month - 1) / 12 : 0);
      const ve = { parsed: yr, raw: String(entry.release_year) };
      if (IS_YR_X) modelMap[ms].vals['__year__'] = ve;
      if (IS_YR_Y) modelMap[ms].vals['__year__'] = ve;
      if (entry.plot_flag === 'approximate') modelMap[ms]._approx = true;
    });
  }

  const allModels = Object.values(modelMap);
  const plotModels = allModels.filter(m => m.vals[xMetric] !== undefined && m.vals[yMetric] !== undefined);
  const metricDropped = allModels.length - plotModels.length;

  if (plotModels.length === 0) {
    const hint = (IS_YR_X || IS_YR_Y)
      ? 'No models could be placed — either both metrics are missing for the same model, or none have a verified release date.'
      : `No models have values for both "${xDispName}" and "${yDispName}".`;
    return `<p class="text-slate-500 text-sm p-4">${hint} Try a different combination.</p>`;
  }

  const aiPts = plotModels.filter(m => !m.isHuman);
  const humPts = plotModels.filter(m => m.isHuman);

  const xVals = plotModels.map(m => m.vals[xMetric].parsed);
  const yVals = plotModels.map(m => m.vals[yMetric].parsed);
  const xMin = Math.min(...xVals), xMax = Math.max(...xVals);
  const yMin = Math.min(...yVals), yMax = Math.max(...yVals);
  const xSpan = xMax - xMin || 1, ySpan = yMax - yMin || 1;
  const xPad = IS_YR_X ? 0.5 : xSpan * 0.12;
  const yPad = IS_YR_Y ? 0.5 : ySpan * 0.12;
  const xLo = xMin - xPad, xHi = xMax + xPad;
  const yLo = yMin - yPad, yHi = yMax + yPad;

  const TW = 700, TH = 480;
  const ML = 58, MR = 40, MT = 28, MB = 58;
  const PA = TW - ML - MR, PH = TH - MT - MB;
  const toSx = x => ML + (x - xLo) / (xHi - xLo) * PA;
  const toSy = y => MT + PH - (y - yLo) / (yHi - yLo) * PH;

  const textC   = '#1e293b';
  const dimC    = '#475569';
  const gridC   = '#e2e8f0';
  const aiC     = '#3b82f6';
  const humC    = '#f59e0b';
  const approxC = '#a78bfa';
  const bgC     = '#ffffff';

  function niceTicks(lo, hi, n) {
    const range = hi - lo;
    if (range <= 0) return [lo, hi];
    const rough = range / n;
    const mag = Math.pow(10, Math.floor(Math.log10(rough)));
    const step = [1, 2, 2.5, 5, 10].map(f => f * mag).find(s => range / s <= n + 1) || mag;
    const start = Math.ceil(lo / step) * step;
    const out = [];
    for (let t = start; t <= hi + step * 0.01; t = parseFloat((t + step).toFixed(10))) out.push(parseFloat(t.toFixed(10)));
    return out;
  }
  function fmtT(v) {
    const a = Math.abs(v);
    if (a === 0) return '0';
    if (a >= 1000) return (v / 1000).toFixed(1) + 'k';
    if (a >= 100) return Math.round(v).toString();
    if (a >= 10) return v.toFixed(1);
    return v.toFixed(2);
  }
  function fmtYr(v) { return Math.round(v).toString(); }

  const xTicks = niceTicks(xLo, xHi, 5);
  const yTicks = niceTicks(yLo, yHi, 5);

  let xGrid = '';
  xTicks.forEach(t => {
    const sx = toSx(t).toFixed(1);
    xGrid += `<line x1="${sx}" y1="${MT}" x2="${sx}" y2="${(MT + PH).toFixed(1)}" stroke="${gridC}" stroke-width="1" stroke-dasharray="3 3"/>`;
    xGrid += `<text x="${sx}" y="${(MT + PH + 14).toFixed(1)}" text-anchor="middle" font-size="9" fill="${dimC}">${IS_YR_X ? fmtYr(t) : fmtT(t)}</text>`;
  });
  let yGrid = '';
  yTicks.forEach(t => {
    const sy = toSy(t).toFixed(1);
    yGrid += `<line x1="${ML}" y1="${sy}" x2="${(ML + PA).toFixed(1)}" y2="${sy}" stroke="${gridC}" stroke-width="1" stroke-dasharray="3 3"/>`;
    yGrid += `<text x="${(ML - 6).toFixed(1)}" y="${sy}" text-anchor="end" dominant-baseline="middle" font-size="9" fill="${dimC}">${IS_YR_Y ? fmtYr(t) : fmtT(t)}</text>`;
  });

  const axes = `<line x1="${ML}" y1="${MT}" x2="${ML}" y2="${(MT + PH).toFixed(1)}" stroke="${dimC}" stroke-width="1.5"/>
    <line x1="${ML}" y1="${(MT + PH).toFixed(1)}" x2="${(ML + PA).toFixed(1)}" y2="${(MT + PH).toFixed(1)}" stroke="${dimC}" stroke-width="1.5"/>`;
  const xLblDisp = (IS_YR_X ? 'Release year (VERIFIER-checked 2026-06)' : xMetric).slice(0, 54);
  const yLblDisp = (IS_YR_Y ? 'Release year (VERIFIER-checked 2026-06)' : yMetric).slice(0, 54);
  const cx = (ML + PA / 2).toFixed(1), cy = (MT + PH / 2).toFixed(1);
  const axLabels = `<text x="${cx}" y="${(MT + PH + 42).toFixed(1)}" text-anchor="middle" font-size="11" fill="${textC}" font-weight="600">${xLblDisp.replace(/&/g,'&amp;').replace(/</g,'&lt;')}</text>
    <text x="${(ML - 40).toFixed(1)}" y="${cy}" text-anchor="middle" font-size="11" fill="${textC}" font-weight="600" transform="rotate(-90 ${(ML - 40).toFixed(1)} ${cy})">${yLblDisp.replace(/&/g,'&amp;').replace(/</g,'&lt;')}</text>`;

  function renderPts(pts, color) {
    return pts.map(m => {
      const sx = toSx(m.vals[xMetric].parsed);
      const sy = toSy(m.vals[yMetric].parsed);
      const rawX = m.vals[xMetric].raw;
      const rawY = m.vals[yMetric].raw;
      const baseLbl = m.model.length > 24 ? m.model.slice(0, 23) + '…' : m.model;
      const fw = m.isHuman ? '700' : '400';
      const nearRight = sx > ML + PA - 90;
      const labelX = (nearRight ? sx - 8 : sx + 8).toFixed(1);
      const anchor = nearRight ? 'end' : 'start';
      const sxf = sx.toFixed(1), syf = sy.toFixed(1);
      const sm = m.model.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
      const lbl = baseLbl.replace(/&/g,'&amp;').replace(/</g,'&lt;');
      const tX = IS_YR_X ? 'Release year' : xMetric;
      const tY = IS_YR_Y ? 'Release year' : yMetric;
      const approxTip = m._approx ? ' (year est.)' : '';

      if (m._approx) {
        const r = 6;
        return `<g>
          <rect x="${(sx - r).toFixed(1)}" y="${(sy - r).toFixed(1)}" width="${2 * r}" height="${2 * r}"
            fill="none" stroke="${approxC}" stroke-width="2" stroke-dasharray="3 2"
            transform="rotate(45 ${sxf} ${syf})"/>
          <circle cx="${sxf}" cy="${syf}" r="2" fill="${approxC}" opacity="0.65"/>
          <title>${sm}: ${tX}=${rawX}${approxTip}, ${tY}=${rawY}</title>
          <text x="${labelX}" y="${(sy - 10).toFixed(1)}" text-anchor="${anchor}" font-size="10" fill="${approxC}" font-weight="${fw}" opacity="0.9">${lbl} ◎</text>
        </g>`;
      }
      return `<g>
        <circle cx="${sxf}" cy="${syf}" r="5.5" fill="${color}" opacity="${m.isHuman ? '0.85' : '0.78'}" stroke="${bgC}" stroke-width="1.5"/>
        <title>${sm}: ${tX}=${rawX}, ${tY}=${rawY}</title>
        <text x="${labelX}" y="${(sy - 9).toFixed(1)}" text-anchor="${anchor}" font-size="10" fill="${m.isHuman ? color : textC}" font-weight="${fw}" opacity="0.88">${lbl}</text>
      </g>`;
    }).join('');
  }

  const ptsHtml = renderPts(aiPts, aiC) + renderPts(humPts, humC);

  let notes = '';
  if (metricDropped > 0) {
    notes += `<p class="text-amber-700 text-xs mt-2">⚠ ${metricDropped} model${metricDropped > 1 ? 's' : ''} omitted — no value for both "${xDispName}" and "${yDispName}"</p>`;
  }
  if (yearOmitCount > 0) {
    notes += `<p class="text-amber-700 text-xs mt-1">⚠ ${yearOmitCount} model${yearOmitCount > 1 ? 's' : ''} omitted — no verified release date (plot_flag=omit)</p>`;
  }
  if (plotModels.some(m => m._approx)) {
    notes += `<p class="text-violet-700 text-xs mt-1">◈ = year estimated from indirect evidence (approximate)</p>`;
  }

  const yearNote = (IS_YR_X || IS_YR_Y)
    ? `<p class="text-slate-500 text-xs mb-2">Release dates: CURATOR 0.3.8 / DISCOVERER 0.12.0 · corrected VERIFIER 0.5.20 F-051a/b · all dates "claimed [VERIFY]" · sourced 2026-06</p>`
    : '';

  const svg = `<svg viewBox="0 0 ${TW} ${TH}" width="100%" style="max-width:${TW}px;display:block" role="img" aria-label="Scatter: ${xDispName} vs ${yDispName}">
    <title>${xDispName} vs ${yDispName} — scatter (source-confirmed, CRAFTER 0.6.0)</title>
    <rect width="${TW}" height="${TH}" fill="${bgC}" opacity="0.5"/>
    ${xGrid}${yGrid}${axes}${axLabels}${ptsHtml}
  </svg>`;

  return yearNote + svg + (notes ? `<div class="mt-2">${notes}</div>` : '');
}

// ── Init ───────────────────────────────────────────────────────────────────
function init() {
  // Benchmark selector
  buildBmSelect();
  const bmSel = document.getElementById('lbBmSel');
  if (bmSel) bmSel.addEventListener('change', e => {
    _lbRid = e.target.value;
    const metrics = getMetrics(_lbRid);
    _lbMetric = metrics[0] || null;
    _lbXMetric = metrics[0] || null;
    _lbYMetric = metrics[1] || metrics[0] || null;
    buildMetSelect(metrics, _lbMetric, 'lbMetSel');
    buildAxisSelect(metrics, _lbXMetric, 'lbXSel');
    buildAxisSelect(metrics, _lbYMetric, 'lbYSel');
    renderChart();
  });

  // Mode buttons
  document.getElementById('modeBar')?.addEventListener('click', () => setMode('bar'));
  document.getElementById('modeScatter')?.addEventListener('click', () => setMode('scatter'));

  // Metric select (bar)
  const metSel = document.getElementById('lbMetSel');
  if (metSel) metSel.addEventListener('change', e => {
    _lbMetric = e.target.value;
    renderChart();
  });

  // Axis selects (scatter)
  const xSel = document.getElementById('lbXSel');
  if (xSel) xSel.addEventListener('change', e => {
    _lbXMetric = e.target.value;
    renderChart();
  });
  const ySel = document.getElementById('lbYSel');
  if (ySel) ySel.addEventListener('change', e => {
    _lbYMetric = e.target.value;
    renderChart();
  });

  // Seed defaults from first chartable benchmark
  const firstChartable = Array.from(LB_PILOT)[0] || 'R001';
  if (!_lbRid || !LB_PILOT.has(_lbRid)) _lbRid = firstChartable;
  const metrics = getMetrics(_lbRid);
  _lbMetric = metrics[0] || null;
  _lbXMetric = metrics[0] || null;
  _lbYMetric = metrics[1] || metrics[0] || null;

  buildBmSelect();
  buildMetSelect(metrics, _lbMetric, 'lbMetSel');
  buildAxisSelect(metrics, _lbXMetric, 'lbXSel');
  buildAxisSelect(metrics, _lbYMetric, 'lbYSel');
  renderChart();
}

// Run after DOM ready
if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', init);
} else {
  init();
}
</script>
