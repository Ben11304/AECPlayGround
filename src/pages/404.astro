---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Not Found">
  <div class="flex min-h-[60vh] flex-col items-center justify-center px-4 text-center">
    <p class="text-7xl font-bold text-slate-800">404</p>
    <h1 class="mt-4 text-2xl font-semibold text-slate-300">Benchmark not found</h1>
    <p class="mt-2 text-sm text-slate-500">
      This benchmark record does not exist in the catalog.
    </p>
    <a
      href={`${import.meta.env.BASE_URL}`}
      class="mt-6 rounded-lg bg-blue-600 px-5 py-2 text-sm font-medium text-white hover:bg-blue-500 transition-colors"
    >
      ← Back to Catalog
    </a>
  </div>
</Layout>
