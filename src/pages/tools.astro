    case 'Scan-to-BIM/Reality-Capture AI':
      return `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
        <circle cx="14" cy="5" r="2" fill="currentColor"/>
        <line x1="14" y1="5" x2="4" y2="22" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="14" y1="5" x2="10" y2="22" stroke="currentColor" stroke-width="1" stroke-linecap="round" opacity="0.55"/>
        <line x1="14" y1="5" x2="14" y2="22" stroke="currentColor" stroke-width="1" stroke-linecap="round" opacity="0.55"/>
        <line x1="14" y1="5" x2="18" y2="22" stroke="currentColor" stroke-width="1" stroke-linecap="round" opacity="0.55"/>
        <line x1="14" y1="5" x2="24" y2="22" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="2" y1="23" x2="26" y2="23" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
