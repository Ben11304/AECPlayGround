---
import Layout from '../layouts/Layout.astro';
import { tools, clusters, clusterColorCls, accessCls, accessLabel, maturityLabel, maturityCls } from '../lib/tools';

const byCluster: Record<string, typeof tools> = {};
for (const cluster of clusters) {
  byCluster[cluster] = tools.filter(t => t.category_cluster === cluster);
}

const openCount = tools.filter(t => t.access === 'open-source').length;
const commercialCount = tools.filter(t => t.access === 'commercial').length;

// Cluster → schematic SVG glyph (28×28)
function clusterGlyphSvg(cluster: string): string {
  switch (cluster) {
    case 'BIM/IFC AI':
      return `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
        <rect x="4" y="10" width="14" height="14" rx="1" stroke="currentColor" stroke-width="1.5" fill="none"/>
        <rect x="10" y="4" width="14" height="14" rx="1" stroke="currentColor" stroke-width="1.5" fill="none"/>
        <line x1="4" y1="10" x2="10" y2="4" stroke="currentColor" stroke-width="1.5"/>
        <line x1="18" y1="10" x2="24" y2="4" stroke="currentColor" stroke-width="1.5"/>
        <line x1="4" y1="24" x2="10" y2="18" stroke="currentColor" stroke-width="1.5"/>
        <line x1="18" y1="24" x2="24" y2="18" stroke="currentColor" stroke-width="1.5"/>
      </svg>`;
    case 'Code/Compliance AI':
      return `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
        <rect x="5" y="3" width="18" height="22" rx="2" stroke="currentColor" stroke-width="1.5" fill="none"/>
        <line x1="9" y1="9" x2="19" y2="9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="9" y1="13" x2="19" y2="13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <polyline points="9,18 12,21 19,16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
      </svg>`;
    case 'Drawing/Takeoff AI':
      return `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
        <rect x="3" y="12" width="22" height="6" rx="1.5" stroke="currentColor" stroke-width="1.5" fill="none"/>
        <line x1="7" y1="12" x2="7" y2="15" stroke="currentColor" stroke-width="1.2"/>
        <line x1="11" y1="12" x2="11" y2="16" stroke="currentColor" stroke-width="1.2"/>
        <line x1="15" y1="12" x2="15" y2="15" stroke="currentColor" stroke-width="1.2"/>
        <line x1="19" y1="12" x2="19" y2="16" stroke="currentColor" stroke-width="1.2"/>
        <line x1="5" y1="8" x2="23" y2="8" stroke="currentColor" stroke-width="1.5" stroke-dasharray="2 2"/>
      </svg>`;
    case 'Generative Design AI':
      return `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
        <path d="M14 4 L15.5 11 L22 12 L15.5 13 L14 20 L12.5 13 L6 12 L12.5 11 Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" fill="none"/>
        <path d="M22 5 L22.8 7.5 L25 8 L22.8 8.5 L22 11 L21.2 8.5 L19 8 L21.2 7.5 Z" stroke="currentColor" stroke-width="1" stroke-linejoin="round" fill="none"/>
        <path d="M6 18 L6.5 20 L8.5 20.5 L6.5 21 L6 23 L5.5 21 L3.5 20.5 L5.5 20 Z" stroke="currentColor" stroke-width="1" stroke-linejoin="round" fill="none"/>
