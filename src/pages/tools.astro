        <line x1="3" y1="11" x2="3" y2="5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="25" y1="19" x2="25" y2="25" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
