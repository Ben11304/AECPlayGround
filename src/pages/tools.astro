    case 'Construction Site Monitoring AI':
      return `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
        <rect x="4" y="9" width="20" height="14" rx="2" stroke="currentColor" stroke-width="1.5" fill="none"/>
        <circle cx="14" cy="16" r="4" stroke="currentColor" stroke-width="1.5" fill="none"/>
        <circle cx="14" cy="16" r="1.5" fill="currentColor"/>
