    case 'Digital Twin AI':
      return `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
        <rect x="2" y="8" width="10" height="12" rx="1.5" stroke="currentColor" stroke-width="1.5" fill="none"/>
        <rect x="16" y="8" width="10" height="12" rx="1.5" stroke="currentColor" stroke-width="1.5" stroke-dasharray="3 2" fill="none"/>
        <line x1="12" y1="14" x2="16" y2="14" stroke="currentColor" stroke-width="1" stroke-dasharray="1.5 1.5"/>
        <path d="M13.5 12.5 L12 14 L13.5 15.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M14.5 12.5 L16 14 L14.5 15.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>`;
    case 'Drone/Aerial AI':
      return `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
        <circle cx="14" cy="14" r="3" stroke="currentColor" stroke-width="1.5" fill="none"/>
        <line x1="14" y1="11" x2="14" y2="6" stroke="currentColor" stroke-width="1.5"/>
        <line x1="17" y1="14" x2="22" y2="14" stroke="currentColor" stroke-width="1.5"/>
        <line x1="14" y1="17" x2="14" y2="22" stroke="currentColor" stroke-width="1.5"/>
        <line x1="11" y1="14" x2="6" y2="14" stroke="currentColor" stroke-width="1.5"/>
        <ellipse cx="14" cy="5" rx="3.5" ry="1.2" stroke="currentColor" stroke-width="1.2" fill="none"/>
        <ellipse cx="23" cy="14" rx="1.2" ry="3.5" stroke="currentColor" stroke-width="1.2" fill="none"/>
        <ellipse cx="14" cy="23" rx="3.5" ry="1.2" stroke="currentColor" stroke-width="1.2" fill="none"/>
        <ellipse cx="5" cy="14" rx="1.2" ry="3.5" stroke="currentColor" stroke-width="1.2" fill="none"/>
