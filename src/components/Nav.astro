---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const navLinks = [
  { href: `${base}/`,               label: 'Home' },
  { href: `${base}/benchmarks`,     label: 'Benchmarks' },
  { href: `${base}/tools`,          label: 'Tools' },
  { href: `${base}/landscape`,      label: 'Landscape' },
  { href: `${base}/landscape-tier4`,label: 'AEC Datasets' },
  { href: `${base}/leaderboard`,    label: 'Leaderboard' },
  { href: `${base}/about`,          label: 'About' },
];

const currentPath = Astro.url.pathname;
function isActive(href: string) {
  if (href === `${base}/`) return currentPath === `${base}/` || currentPath === base;
  return currentPath.startsWith(href);
}
---

<header class="sticky top-0 z-50 border-b border-slate-200/80 bg-white/90 backdrop-blur-md">
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3 sm:px-6 lg:px-8">

    <!-- Desktop nav links -->
    <div class="hidden md:flex items-center gap-0.5">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class={[
            'relative rounded-lg px-3.5 py-2 text-sm font-medium transition-all duration-150',
            isActive(href)
              ? 'text-slate-900 bg-slate-100'
              : 'text-slate-600 hover:text-slate-800 hover:bg-slate-100/60',
          ].join(' ')}
          aria-current={isActive(href) ? 'page' : undefined}
        >
          {label}
          {isActive(href) && (
            <span class="absolute bottom-0 left-1/2 -translate-x-1/2 h-[2px] w-4 rounded-full bg-primary-500" />
          )}
        </a>
      ))}
    </div>

    <!-- Right controls -->
    <div class="flex items-center gap-1.5">
      <!-- Data download link -->
      <a
        href={`${base}/data/benchmarks.json`}
        download
        class="hidden sm:flex rounded-lg px-3 py-1.5 text-xs font-medium text-slate-600 border border-slate-200 hover:border-slate-600 hover:text-slate-800 hover:bg-slate-100 transition-all gap-1.5 items-center"
        aria-label="Download benchmark data JSON"
      >
        <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M8 1v10M4 7l4 4 4-4"/>
          <path d="M2 13h12" stroke-linecap="round"/>
        </svg>
        JSON
      </a>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="md:hidden rounded-lg p-2 text-slate-600 hover:bg-slate-100 hover:text-slate-800 transition-colors"
        aria-label="Toggle navigation menu"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile dropdown -->
  <div
    id="mobile-menu"
    aria-hidden="true"
    class="hidden md:hidden border-t border-slate-200 bg-white px-4 pb-4 pt-2"
  >
    {navLinks.map(({ href, label }) => (
      <a
        href={href}
        class={[
          'block rounded-lg px-3 py-2.5 text-sm font-medium transition-colors',
          isActive(href)
            ? 'bg-slate-100 text-slate-900'
            : 'text-slate-600 hover:bg-slate-100/60 hover:text-slate-800',
        ].join(' ')}
      >
        {label}
      </a>
    ))}
    <div class="mt-3 pt-3 border-t border-slate-200">
      <a href={`${base}/data/benchmarks.json`} download class="flex items-center gap-2 px-3 py-2 text-xs text-slate-500 hover:text-slate-700 transition-colors">
        <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M8 1v10M4 7l4 4 4-4"/><path d="M2 13h12" stroke-linecap="round"/>
        </svg>
        Download benchmarks.json
      </a>
    </div>
  </div>
</header>
