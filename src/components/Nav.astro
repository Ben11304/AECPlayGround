---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const navLinks = [
  { href: `${base}/`,                label: 'Home' },
  { href: `${base}/benchmarks`,      label: 'Benchmarks' },
  { href: `${base}/tools`,           label: 'Tools' },
  { href: `${base}/landscape`,       label: 'Landscape' },
  { href: `${base}/landscape-tier4`, label: 'AEC Datasets' },
  { href: `${base}/leaderboard`,     label: 'Leaderboard' },
  { href: `${base}/about`,           label: 'About' },
];

const currentPath = Astro.url.pathname;
function isActive(href: string) {
  if (href === `${base}/`) return currentPath === `${base}/` || currentPath === base;
  return currentPath.startsWith(href);
}
---

<header class="sticky top-[3px] z-50 border-b border-rule bg-paper">
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3 sm:px-6 lg:px-8">

    <!-- Wordmark — serif display, left side -->
    <a
      href={`${base}/`}
      class="font-display text-sm font-bold tracking-tight text-ink hover:text-primary-700 transition-colors no-underline"
      aria-label="AECplayground home"
    >
      AECplayground
    </a>

    <!-- Desktop nav links -->
    <div class="hidden md:flex items-center gap-0">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class={[
            'relative px-3.5 py-2 text-[13px] font-medium transition-colors duration-150',
            isActive(href)
              ? 'text-ink'
              : 'text-muted hover:text-ink',
          ].join(' ')}
          aria-current={isActive(href) ? 'page' : undefined}
        >
          {label}
          {isActive(href) && (
            <span class="absolute bottom-0 left-3.5 right-3.5 h-[2px] bg-primary-700" />
          )}
        </a>
      ))}
    </div>

    <!-- Right controls -->
    <div class="flex items-center gap-2">
      <!-- JSON download -->
      <a
        href={`${base}/data/benchmarks.json`}
        download
        class="hidden sm:flex items-center gap-1.5 px-2.5 py-1.5 text-[11px] font-mono font-medium text-muted border border-rule hover:border-primary-700 hover:text-primary-700 transition-colors"
        style="border-radius: 0.25rem;"
        aria-label="Download benchmark data JSON"
      >
        <svg width="11" height="11" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M8 1v10M4 7l4 4 4-4"/>
          <path d="M2 13h12" stroke-linecap="round"/>
        </svg>
        JSON
      </a>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="md:hidden p-2 text-muted hover:text-ink transition-colors"
        aria-label="Toggle navigation menu"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile dropdown -->
  <div
    id="mobile-menu"
    aria-hidden="true"
    class="hidden md:hidden border-t border-rule bg-paper px-4 pb-4 pt-2"
  >
    {navLinks.map(({ href, label }) => (
      <a
        href={href}
        class={[
          'block px-3 py-2.5 text-sm font-medium transition-colors border-b border-rule last:border-b-0',
          isActive(href)
            ? 'text-ink'
            : 'text-muted hover:text-ink',
        ].join(' ')}
        aria-current={isActive(href) ? 'page' : undefined}
      >
        {label}
      </a>
    ))}
    <div class="mt-3 pt-3 border-t border-rule">
      <a
        href={`${base}/data/benchmarks.json`}
        download
        class="flex items-center gap-2 px-3 py-2 text-xs font-mono text-muted hover:text-primary-700 transition-colors"
      >
        <svg width="11" height="11" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M8 1v10M4 7l4 4 4-4"/>
          <path d="M2 13h12" stroke-linecap="round"/>
        </svg>
        Download benchmarks.json
      </a>
    </div>
  </div>
</header>
