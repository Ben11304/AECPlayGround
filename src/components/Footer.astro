---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<footer class="border-t border-slate-800 bg-slate-950 mt-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

    <!-- Main footer grid -->
    <div class="grid grid-cols-2 gap-8 py-12 md:grid-cols-4">

      <!-- Brand column -->
      <div class="col-span-2 md:col-span-1">
        <div class="flex items-center gap-2.5 mb-3">
          <div class="flex h-7 w-7 items-center justify-center rounded-lg bg-gradient-to-br from-primary-500 to-primary-700">
            <svg width="13" height="13" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <rect x="1" y="9" width="3" height="6" rx="0.5" fill="white" opacity="0.55"/>
              <rect x="5.5" y="5" width="3" height="10" rx="0.5" fill="white" opacity="0.75"/>
              <rect x="10" y="1" width="5" height="14" rx="0.5" fill="white"/>
            </svg>
          </div>
          <span class="font-display font-bold text-sm text-white">AECplayground</span>
        </div>
        <p class="text-xs text-slate-500 leading-relaxed max-w-[200px]">
          A dual registry: 26 AI benchmarks and 47 curated tools for Architecture, Engineering &amp; Construction.
        </p>
      </div>

      <!-- Explore -->
      <div>
        <h3 class="text-xs font-semibold text-slate-300 uppercase tracking-widest mb-3">Explore</h3>
        <ul class="space-y-2 text-xs">
          <li><a href={`${base}/`}            class="text-slate-500 hover:text-slate-300 transition-colors">Home</a></li>
          <li><a href={`${base}/benchmarks`} class="text-slate-500 hover:text-slate-300 transition-colors">All Benchmarks</a></li>
          <li><a href={`${base}/tools`}      class="text-slate-500 hover:text-slate-300 transition-colors">AI Tools</a></li>
          <li><a href={`${base}/landscape`}       class="text-slate-500 hover:text-slate-300 transition-colors">Landscape</a></li>
          <li><a href={`${base}/landscape-tier4`} class="text-slate-500 hover:text-slate-300 transition-colors">AEC Dataset Landscape (T4)</a></li>
          <li><a href={`${base}/leaderboard`}     class="text-slate-500 hover:text-slate-300 transition-colors">Leaderboard</a></li>
          <li><a href={`${base}/about`}       class="text-slate-500 hover:text-slate-300 transition-colors">About &amp; Methodology</a></li>
        </ul>
      </div>

      <!-- Data -->
      <div>
        <h3 class="text-xs font-semibold text-slate-300 uppercase tracking-widest mb-3">Data</h3>
        <ul class="space-y-2 text-xs">
          <li>
            <a href={`${base}/data/benchmarks.json`} class="text-slate-500 hover:text-slate-300 transition-colors">
              benchmarks.json
            </a>
          </li>
          <li>
            <a href={`${base}/data/tier4_datasets.json`} class="text-slate-500 hover:text-slate-300 transition-colors">
              tier4_datasets.json
            </a>
          </li>
          <li><span class="text-slate-600">26 benchmarks · 47 tools · CRAFTER v0.7.15</span></li>
          <li><span class="text-slate-600">CURATOR 0.5.3</span></li>
          <li><span class="text-slate-600">SYNTHESIZER 0.5.5</span></li>
          <li><span class="text-slate-600">VERIFIER 0.5.38</span></li>
        </ul>
      </div>

      <!-- Review -->
      <div>
        <h3 class="text-xs font-semibold text-slate-300 uppercase tracking-widest mb-3">Review</h3>
        <ul class="space-y-2 text-xs">
          <li><span class="text-slate-600">PRISMA 4-Arm Protocol</span></li>
          <li><span class="text-slate-600">164 identified</span></li>
          <li><span class="text-slate-600">26 included</span></li>
          <li><span class="text-slate-600">T1 18 · T2 7 · T3 1</span></li>
          <li><span class="text-slate-600">92 Tier-4 background datasets</span></li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-slate-800 py-6">
      <p class="text-[11px] text-slate-700 leading-relaxed text-center max-w-3xl mx-auto">
        Benchmark thumbnails are figures from the original papers, shown for identification under fair use; copyright belongs to the original authors.
      </p>
      <p class="text-[11px] text-slate-700 leading-relaxed text-center max-w-3xl mx-auto mt-2">
        All data sourced from published research; no data is fabricated.
        Numbers marked <code class="font-mono text-amber-700/80">[VERIFY]</code> are claimed by authors and not yet independently confirmed.
        R032 excluded per VERIFIER 0.5.23 F-054 (framework-internal, no public release).
        R038 excluded as EX-CONSOL (duplicate of R008).
        R035/R036/R037/R039/R040/R041 screened (Stage 2 INCLUDE; full-text VERIFIER re-gate pending).
        Built with <a href="https://astro.build" target="_blank" rel="noopener" class="text-slate-600 hover:text-slate-400 transition-colors">Astro</a>
        + <a href="https://tailwindcss.com" target="_blank" rel="noopener" class="text-slate-600 hover:text-slate-400 transition-colors">Tailwind</a>.
      </p>
    </div>
  </div>
</footer>
