---
import { benchmarks } from '../lib/benchmarks';
import { tools } from '../lib/tools';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<footer class="border-t border-rule bg-paper mt-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

    <!-- Main footer grid -->
    <div class="grid grid-cols-2 gap-8 py-12 md:grid-cols-4">

      <!-- Brand column -->
      <div class="col-span-2 md:col-span-1">
        <div class="mb-3">
          <a href={`${base}/`} class="font-display text-sm font-bold text-ink hover:text-primary-700 transition-colors no-underline">
            AECplayground
          </a>
        </div>
        <p class="text-xs text-muted leading-relaxed max-w-[200px]">
          A dual registry: {benchmarks.length} AI benchmarks and {tools.length} curated tools for Architecture, Engineering &amp; Construction.
        </p>
      </div>

      <!-- Explore -->
      <div>
        <h3 class="text-[10px] font-mono font-medium text-ink uppercase tracking-widest mb-3">Explore</h3>
        <ul class="space-y-2 text-xs">
          <li><a href={`${base}/`}                class="text-muted hover:text-ink transition-colors">Home</a></li>
          <li><a href={`${base}/benchmarks`}      class="text-muted hover:text-ink transition-colors">All Benchmarks</a></li>
          <li><a href={`${base}/tools`}           class="text-muted hover:text-ink transition-colors">AI Tools</a></li>
          <li><a href={`${base}/landscape`}       class="text-muted hover:text-ink transition-colors">Landscape</a></li>
          <li><a href={`${base}/landscape-tier4`} class="text-muted hover:text-ink transition-colors">AEC Dataset Landscape (T4)</a></li>
          <li><a href={`${base}/leaderboard`}     class="text-muted hover:text-ink transition-colors">Leaderboard</a></li>
          <li><a href={`${base}/about`}           class="text-muted hover:text-ink transition-colors">About &amp; Methodology</a></li>
        </ul>
      </div>

      <!-- Data -->
      <div>
        <h3 class="text-[10px] font-mono font-medium text-ink uppercase tracking-widest mb-3">Data</h3>
        <ul class="space-y-2 text-xs">
          <li>
            <a href={`${base}/data/benchmarks.json`} class="text-muted hover:text-ink transition-colors font-mono">
              benchmarks.json
            </a>
          </li>
          <li>
            <a href={`${base}/data/tier4_datasets.json`} class="text-muted hover:text-ink transition-colors font-mono">
              tier4_datasets.json
            </a>
          </li>
          <li><span class="text-muted">{benchmarks.length} benchmarks · {tools.length} tools · CRAFTER v0.12.0</span></li>
          <li><span class="text-muted">RESEARCHER 0.24.0</span></li>
          <li><span class="text-muted">VERIFIER 0.5.63</span></li>
        </ul>
      </div>

      <!-- Review -->
      <div>
        <h3 class="text-[10px] font-mono font-medium text-ink uppercase tracking-widest mb-3">Review</h3>
        <ul class="space-y-2 text-xs">
          <li><span class="text-muted">PRISMA 4-Arm Protocol</span></li>
          <li><span class="text-muted">164 identified</span></li>
          <li><span class="text-muted">26 included</span></li>
          <li><span class="text-muted">T1 18 · T2 7 · T3 1</span></li>
          <li><span class="text-muted">92 Tier-4 background datasets</span></li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-rule py-6 space-y-2">
      <p class="text-[11px] text-muted leading-relaxed text-center max-w-3xl mx-auto">
        Benchmark thumbnails are figures from the original papers, shown for identification under fair use; copyright belongs to the original authors.
      </p>
      <p class="text-[11px] text-muted leading-relaxed text-center max-w-3xl mx-auto">
        All data sourced from published research; no data is fabricated.
        Numbers marked <code class="font-mono text-t2-700">[VERIFY]</code> are claimed by authors and not yet independently confirmed.
        R032 excluded per VERIFIER 0.5.23 F-054 (framework-internal, no public release).
        R038 excluded as EX-CONSOL (duplicate of R008).
        R035/R036/R037/R039/R040/R041 screened (Stage 2 INCLUDE; full-text VERIFIER re-gate pending).
        Built with <a href="https://astro.build" target="_blank" rel="noopener" class="text-ink hover:text-primary-700 transition-colors">Astro</a>
        + <a href="https://tailwindcss.com" target="_blank" rel="noopener" class="text-ink hover:text-primary-700 transition-colors">Tailwind</a>.
      </p>
    </div>
  </div>
</footer>
